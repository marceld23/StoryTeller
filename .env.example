# Kopiere diese Datei nach .env und trage deinen Schlüssel ein.
# (Eine .env mit echtem Key wurde bereits angelegt; chmod 600.)
OPENAI_API_KEY=sk-proj-...

# Optional: schützt die Web-Backends (Admin :8080 + Player :8090) mit einem
# gemeinsamen Token. Leer/ungesetzt = kein Schutz (offenes LAN). Ist es
# gesetzt, fragt das Frontend beim ersten 401 danach und merkt es sich.
# STORYTELLER_WEB_TOKEN=ein-langes-zufaelliges-geheimnis
