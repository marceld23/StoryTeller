# Copy this file to .env and fill in your key.
# (A .env with a real key may already exist; chmod 600 it.)
OPENAI_API_KEY=sk-proj-...

# Passwords for the web frontends (empty/unset = no protection, open LAN).
# The frontend prompts for the token on first load and remembers it.
# Changes take effect immediately (no restart required).
#   STORYTELLER_ADMIN_TOKEN : Admin frontend (:8080). Falls back to WEB_TOKEN.
#   STORYTELLER_WEB_TOKEN   : Player frontend (:8090).
# STORYTELLER_ADMIN_TOKEN=a-long-admin-password
# STORYTELLER_WEB_TOKEN=a-long-player-password

# Per-operator locale override. The repo default in config/config.toml is
# "en". Set this to "de" to run a single deployment in German without
# changing the committed default.
# STORYTELLER_LOCALE=de
