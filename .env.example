# Kopiere diese Datei nach .env und trage deinen Schlüssel ein.
# (Eine .env mit echtem Key wurde bereits angelegt; chmod 600.)
OPENAI_API_KEY=sk-proj-...

# Passwörter für die Web-Frontends (leer/ungesetzt = kein Schutz, offenes LAN).
# Beim ersten Aufruf fragt das Frontend danach und merkt es sich.
# Änderungen wirken sofort (kein Neustart nötig).
#   STORYTELLER_ADMIN_TOKEN : Admin-Frontend (:8080). Fällt auf WEB_TOKEN zurück.
#   STORYTELLER_WEB_TOKEN   : Player-Frontend (:8090).
# STORYTELLER_ADMIN_TOKEN=ein-langes-admin-passwort
# STORYTELLER_WEB_TOKEN=ein-langes-player-passwort
