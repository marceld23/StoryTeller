# Personal scratch / planning notes — not for the repo
next.md

# Secrets
.env
# TLS material (certs + private keys). The HTTPS setup
# (scripts/install_https.sh + docs/SETUP_HTTPS.md) places everything
# under /etc/storyteller/mkcert/, NOT in the repo — but a defense-in-
# depth ignore here makes sure a stray copy never lands in a commit.
*.pem
*.key
*.crt
*.pfx
*.p12

# Python / uv
.venv/
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# Node / yarn / SvelteKit
node_modules/
.svelte-kit/
.yarn/cache
.yarn/install-state.gz
apps/**/build/

# LangGraph checkpointer (per-session story state)
data/checkpoints.db
data/checkpoints.db-*

# Laufzeitdaten
data/saves/
data/rag.db
data/rag.db-*
data/rag.*.db
data/rag.*.db-*
data/*.log
*.wav
*.tmp
# Regenerable audio caches (rebuild: storyteller voice-prompts / wait-sounds):
data/voice_prompts/
# Wait sounds: ignore everything in the directory except the two default
# ambient files that ship with the repo (re-generated from ambient.py
# whenever the generator changes, see `write_ambient()`). Note the
# `dir/*` form — `dir/` excludes the directory itself and would block
# any negation below.
data/wait_sounds/*
!data/wait_sounds/fantasy_ambient.wav
!data/wait_sounds/scifi_ambient.wav
!data/wait_sounds/fantasy_waiting.wav
!data/wait_sounds/scifi_waiting.wav
!data/wait_sounds/generic_waiting.wav

%APPDATA%/*

# OS
.DS_Store
data/moderation.json
data/transcripts/

# Worlds: keep only the seed worlds in git; ignore generated/admin worlds
data/worlds/*
!data/worlds/sternenfahrt.json
!data/worlds/sternenfahrt.en.json
!data/worlds/immerwald.json
!data/worlds/immerwald.en.json
data/audio.json
data/settings.json
data/models*.json
data/story.json
data/cost.json
data/cost.jsonl
# Endpoint health status — runtime artefact written by HealthRegistry
# in storyteller_core.health; regenerates itself on first call.
data/health.json
