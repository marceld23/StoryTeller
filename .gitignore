# Secrets
.env

# Python / uv
.venv/
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# Node / yarn / SvelteKit
node_modules/
.svelte-kit/
.yarn/cache
.yarn/install-state.gz
apps/**/build/

# LangGraph checkpointer (per-session story state)
data/checkpoints.db
data/checkpoints.db-*

# Laufzeitdaten
data/saves/
data/rag.db
data/rag.db-*
data/*.log
*.wav
*.tmp
# Regenerable audio caches (rebuild: storyteller voice-prompts / wait-sounds):
data/voice_prompts/
data/wait_sounds/
# Except: ship the two default ambient files so a fresh clone works
# out of the box (re-generated from ambient.py whenever the generator
# changes, see `write_ambient()`).
!data/wait_sounds/fantasy_ambient.wav
!data/wait_sounds/scifi_ambient.wav

%APPDATA%/*

# OS
.DS_Store
data/moderation.json
data/transcripts/

# Worlds: keep only the seed worlds in git; ignore generated/admin worlds
data/worlds/*
!data/worlds/sternenfahrt.json
!data/worlds/sternenfahrt.en.json
!data/worlds/immerwald.json
!data/worlds/immerwald.en.json
data/audio.json
data/settings.json
data/models.json
data/models_local.json
data/story.json
