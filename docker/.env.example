# Copy this file to `.env` (same directory) and fill in the values.
# docker-compose injects everything into both web-ui and web-admin
# containers via `env_file: .env`.

# ----- LLM / TTS / STT provider keys -----
# Choose ONE of these (or both, if you mix providers per role).
# Empty values are fine — the engine falls through to defaults from
# config.toml. Local self-hosted servers (Ollama / XTTS / faster-whisper)
# don't need a key here; they pick up the local IP from data/models.json
# via the admin UI.

OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ----- Admin access control -----
# Set to a non-empty value to require a Bearer token on /api/* in the
# admin backend. The admin UI prompts for it on first 401 and stores
# it in localStorage. EMPTY = no authentication, anyone on the network
# can edit worlds and trigger LLM calls — only acceptable in a
# trusted LAN.
STORYTELLER_ADMIN_TOKEN=

# Same gate for the player web-ui (less critical; players don't have
# destructive endpoints). Leave empty for a public LAN install.
STORYTELLER_WEB_TOKEN=
